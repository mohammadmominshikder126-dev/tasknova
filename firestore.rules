rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 3. Primitive Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == 'mohammadmominshikder126@gmail.com' && request.auth.token.email_verified == true)
      );
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid == request.auth.uid 
          && (!('email' in data) || (data.email is string && data.email.size() <= 100))
          && (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100))
          && (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500))
          && data.balance is number
          && data.totalEarned is number
          && data.totalWithdrawn is number
          && (!('referralCode' in data) || (data.referralCode is string && data.referralCode.size() <= 64))
          && (!('invitedBy' in data) || (data.invitedBy is string && data.invitedBy.size() <= 128))
          && (!('activePackageId' in data) || (data.activePackageId is string))
          && (!('packageExpiry' in data) || (data.packageExpiry is timestamp || data.packageExpiry == null))
          && data.createdAt is timestamp;
    }

    function isValidTransaction(data) {
      return data.userId == request.auth.uid
          && data.amount is number
          && data.type in ['earning', 'withdrawal', 'recharge', 'referral']
          && data.status in ['pending', 'completed', 'rejected']
          && data.createdAt == request.time;
    }

    function isValidTaskLog(data) {
      return data.userId == request.auth.uid
          && data.packageId is string
          && data.date is string && data.date.size() == 10
          && data.count is number && data.count >= 0;
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().balance == 0;
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Allow updating common profile fields or balance (if we trust client for now)
        incoming().diff(existing()).affectedKeys().hasOnly(['balance', 'totalEarned', 'totalWithdrawn', 'activePackageId', 'packageExpiry', 'displayName', 'referralCode', 'photoURL', 'bankCard'])
      );
    }

    match /admins/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
    }

    match /banners/{bannerId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    match /packages/{packageId} {
      allow get, list: if isSignedIn();
      allow write: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidTransaction(incoming());
      allow update: if isAdmin(); // Allow admin to approve/reject
      allow delete: if false;
    }

    match /taskLogs/{logId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidTaskLog(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidTaskLog(incoming());
    }

    match /stats/{docId} {
      allow get: if true;
      allow write: if isSignedIn();
    }

    match /settings/admin {
      allow get: if true;
      allow write: if isAdmin();
    }

    // Public feed for live withdrawals (limited info)
    match /withdrawals_feed/{id} {
      allow list, get: if true; // Publicly readable for the feed
      allow write: if false; // System only
    }
  }
}
